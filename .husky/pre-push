# Fail if package.json or lock file have uncommitted changes
DIRTY_PKG=$(git diff --name-only -- package.json package-lock.json)
if [ -n "$DIRTY_PKG" ]; then
  echo "ERROR: Uncommitted changes in dependency files:"
  echo "$DIRTY_PKG"
  echo "Commit these before pushing or Netlify build will fail."
  exit 1
fi

echo "🔍 Running clean build check before push..."

# Build into a separate directory so we don't destroy the running dev server's .next cache.
# Previously: `rm -rf .next && npm run build` — this corrupted dev server state after every push.
rm -rf .next-prepush
trap 'rm -rf .next-prepush' EXIT

NEXT_BUILD_OUTPUT_DIR=".next-prepush" npm run build

echo "✅ Build passed (dev server cache untouched)"
