{
  "name": "brik-client-portal",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff --use-migra",
    "db:status": "supabase migration list",
    "db:seed": "supabase db reset --db-only",
    "prepare": "husky",
    "maintenance": "./scripts/portal-maintenance.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "audit:tokens": "./scripts/token-audit.sh",
    "deploy:staging": "npx netlify-cli deploy --build",
    "deploy:prod": "npx netlify-cli deploy --build --prod"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@react-email/components": "^1.0.8",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "resend": "^6.9.2",
    "stripe": "^20.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "husky": "^9.1.7",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
